# Required — used to sign tokens and session cookies
SECRET_KEY=change-me-to-a-random-string

# Admin dashboard password
ADMIN_PASSWORD=change-me

# SMTP settings for sending email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_STARTTLS=true

# Email addresses
ADMIN_EMAIL=admin@example.com
FROM_EMAIL=noreply@example.com

# Path to Authelia's users_database.yml inside the container
AUTHELIA_USERS_FILE=/data/users_database.yml

# Public URL of this app (used in email links, no trailing slash)
APP_URL=http://localhost:8085

# Token expiry for approve/deny email links (hours)
TOKEN_EXPIRY_HOURS=48

# Default groups assigned to new users (comma-separated)
DEFAULT_GROUPS=users

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:////data/registrations.db
